LLM_BASE_URL=https://qianfan.baidubce.com/v2/coding
LLM_API_KEY=your_key_here
LLM_MODEL=glm-5

# Embedding（OpenRouter 免费模型，2048维）
EMB_BASE_URL=https://openrouter.ai/api/v1
EMB_API_KEY=your_key_here
EMB_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# ── 目录定义（容器内路径） ──
# /data：Butler 内部持久化数据目录（记忆、历史、索引等）
# DATA_DIR=/data
# /data/memory：长期记忆与历史目录（MEMORY.md、chat_history、索引等）
# MEMORY_DIR=/data/memory
# /data/tool_call：工具返回结果溢出后的落盘目录
# TOOL_CALL_DIR=/data/tool_call
# /workspace：命令执行工作区，也是 Agent 产出/下载文件目录
# WORKSPACE_DIR=/workspace

# 记忆检索：静默注入的相似度阈值（0~1，越高越严格）
MEMORY_SIMILARITY_THRESHOLD=0.5

# Web 搜索
# 当前默认使用内置的百度 / Bing 页面抓取搜索，无需额外 API Key

# ── 命令执行（容器内 subprocess） ──
COMMAND_ENABLED=true
# COMMAND_WORKDIR=/workspace
# COMMAND_DEFAULT_TIMEOUT=30

# ── browser-use（AI 浏览器自动化） ──
# 需要: pip install browser-use && playwright install chromium
BROWSER_ENABLED=true
# BROWSER_HEADLESS=true
# BROWSER_MAX_STEPS=20

# ── 飞书 Channel ──
# 在飞书开放平台创建应用后获取：https://open.feishu.cn/app
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 事件订阅签名密钥（Verification Token），用于校验推送来源
FEISHU_SIGN_SECRET=
# 机器人名称，用于群聊中 @机器人 过滤（留空则群聊消息全部处理）
FEISHU_BOT_NAME=
