LLM_BASE_URL=https://qianfan.baidubce.com/v2/coding
LLM_API_KEY=your_key_here
LLM_MODEL=glm-5

# Embedding（OpenRouter 免费模型，2048维）
EMB_BASE_URL=https://openrouter.ai/api/v1
EMB_API_KEY=your_key_here
EMB_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# ── 数据目录 ──
# 记忆数据存储路径（ReMe、ChromaDB、chat_history、MEMORY.md）
# 容器内默认 /data/memory，本地开发可改为 data/memory
# WORKING_DIR=/data/memory

# 记忆检索：静默注入的相似度阈值（0~1，越高越严格）
MEMORY_SIMILARITY_THRESHOLD=0.5

# Web 搜索（union-search-skill）
# 默认使用 no_api_key 分组，无需配置任何 Key 即可搜索
# 可选：配置以下 Key 解锁更多高质量搜索引擎
# GITHUB_TOKEN=your_token          # GitHub 搜索
# TAVILY_API_KEY=your_key          # Tavily AI 搜索（1000次/月免费）
# TIKHUB_TOKEN=your_token          # 小红书/抖音/B站/Twitter（$5约5000次）

# ── 命令执行（容器内 subprocess） ──
COMMAND_ENABLED=true
# COMMAND_WORKDIR=/workspace
# COMMAND_DEFAULT_TIMEOUT=30

# ── browser-use（AI 浏览器自动化） ──
# 需要: pip install browser-use && playwright install chromium
BROWSER_ENABLED=true
# BROWSER_HEADLESS=true
# BROWSER_MAX_STEPS=20
