# AI Butler 环境配置示例
# 复制此文件为 .env，填入真实值

# LLM（兼容 OpenAI 接口）
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=deepseek/deepseek-chat

# Embedding（OpenRouter 免费模型）
EMB_BASE_URL=https://openrouter.ai/api/v1
EMB_API_KEY=your_openrouter_api_key_here
EMB_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=ai_butler_memory

# 记忆参数
MEMORY_TOP_K=10
MEMORY_DECAY_LAMBDA=0.01
WORKING_MEMORY_TURNS=6
